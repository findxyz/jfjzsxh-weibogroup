# ─────────────────────────────────────────────────────────────
# ⚠️ 安全相关（绝对不能上传）
# ─────────────────────────────────────────────────────────────

# 数据库文件 —— 内含 Cookie (SUB/SUBP 登录票据)，泄露等于账号被盗！
# 同时包含全部群聊消息、媒体清单等隐私数据。
*.db
*.db-shm
*.db-wal
*.db-journal
*.sqlite
*.sqlite3

# 扫码登录二维码截图（可能含可识别信息）
qrcode.png
qrcode-*.png

# .env / 配置覆盖文件（如果你之后用来存本地配置）
.env
.env.*
*.local


# ─────────────────────────────────────────────────────────────
# 运行时产物
# ─────────────────────────────────────────────────────────────

# 下载的媒体文件（图片/视频/附件，可能很大且含群聊隐私）
# 注：保留目录结构，让 clone 后程序能正常 mkdir
media/*
!media/.gitkeep
!media/images/
!media/videos/
!media/files/
media/images/*
media/videos/*
media/files/*
!media/images/.gitkeep
!media/videos/.gitkeep
!media/files/.gitkeep

# 运行日志
*.log
logs/


# ─────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────

# 字节码缓存
__pycache__/
*.py[cod]
*$py.class

# 发行/打包产物
build/
dist/
*.egg-info/
*.egg
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# 虚拟环境
.venv/
venv/
env/
ENV/
.python-version

# 测试 / 类型检查 / 覆盖率
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetokens.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/


